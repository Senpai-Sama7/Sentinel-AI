{
  "dashboard": {
    "id": null,
    "title": "Sentinel API Overview",
    "panels": [
      {
        "type": "graph",
        "title": "API Request Rate",
        "targets": [
          {"expr": "sum(rate(api_requests_total[1m])) by (path)", "legendFormat": "{{path}}"}
        ],
        "datasource": "Prometheus",
        "id": 1
      },
      {
        "type": "graph",
        "title": "API Request Latency (p95)",
        "targets": [
          {"expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}
        ],
        "datasource": "Prometheus",
        "id": 2
      },
      {
        "type": "graph",
        "title": "Cache Hit Ratio (L1)",
        "targets": [
          {"expr": "sum(rate(cache_hits_total{level=\"L1\"}[1m])) / sum(rate(cache_lookups_total{level=\"L1\"}[1m]))", "legendFormat": "L1 Cache Hit Ratio"}
        ],
        "datasource": "Prometheus",
        "id": 3
      }
    ],
    "schemaVersion": 30,
    "version": 1
  }
}